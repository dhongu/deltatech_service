<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="res_groups_privilege_service" model="res.groups.privilege" >
        <field name="name">Service</field>
        <field name="category_id" ref="base.module_category_services"/>
    </record>

    <record id="res_groups_privilege_warranty" model="res.groups.privilege" >
        <field name="name">Warranty</field>
        <field name="category_id" ref="base.module_category_services"/>
    </record>




    <record id="group_service_client" model="res.groups">
        <field name="name">Client</field>
        <field name="privilege_id" ref="res_groups_privilege_service"/>

        <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
        <field name="user_ids" eval="[(4, ref('base.user_root'))]" />
    </record>
    <record id="group_service_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="res_groups_privilege_service"/>
        <field name="implied_ids" eval="[(4, ref('group_service_client'))]" />
    </record>
    <record id="group_service_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_service"/>
        <field name="implied_ids" eval="[(4, ref('group_service_user'))]" />
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]" />
    </record>

    <record id="group_warranty_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="res_groups_privilege_warranty"/>
        <field name="implied_ids" eval="[(4, ref('group_service_user'))]" />
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]" />
    </record>
    <record id="group_warranty_approve" model="res.groups">
        <field name="name">Approval</field>
        <field name="privilege_id" ref="res_groups_privilege_warranty"/>
        <field name="implied_ids" eval="[(4, ref('group_service_user'))]" />
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]" />
    </record>
    <record id="group_warranty_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_warranty"/>
        <field name="implied_ids" eval="[(4, ref('group_service_user')), (4, ref('group_warranty_user'))]" />
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]" />
    </record>


</odoo>
