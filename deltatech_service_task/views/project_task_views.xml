<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="view_task_form2_inherited" model="ir.ui.view">
        <field name="name">project.task.form.inherited</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//field[@name='role_ids']" position="after">
                <field name="service_location_id"  />
                <field name="service_equipment_id" />
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Parts" name="parts">
                    <field name="part_ids" mode="list,kanban">
                        <list editable="bottom">
                            <field name="sequence" widget="handle" />
                            <field name="part_id" />
                            <field name="quantity" />
                            <field name="note" />
                            <field name="is_ok" />
                        </list>
                        <kanban class="o_kanban_mobile">
                            <field name="part_id" />
                            <field name="quantity" />
                            <field name="is_ok" />
                            <field name="note" />
                            <templates>
                                <t t-name="card">
                                    <div class="row">
                                        <div class="col-8">
                                            <strong>
                                                <field name="part_id" />
                                            </strong>
                                        </div>
                                        <div class="col-4 text-end">
                                            <field name="is_ok" widget="boolean_favorite" nolabel="1" />
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-12 text-muted">
                                            Cantitate: <field name="quantity" />
                                        </div>
                                    </div>
                                    <div class="row" t-if="record.note.raw_value">
                                        <div class="col-12">
                                            <field name="note" />
                                        </div>
                                    </div>
                                </t>
                            </templates>
                        </kanban>
                    </field>
                </page>
            </xpath>
        </field>
    </record>


     <record id="view_task_search_form_inherited" model="ir.ui.view">
        <field name="name">project.task.form.inherited</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_search_form"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='private_tasks']" position="after">
                <field name="service_location_id"/>
                <field name="service_equipment_id"/>
                <filter string="Functional Location" name="service_location"
                        context="{'group_by': 'service_location_id'}"/>
                <filter string="Service Equipment" name="service_equipment"
                        context="{'group_by': 'service_equipment_id'}"/>
            </xpath>
        </field>
    </record>

</odoo>
