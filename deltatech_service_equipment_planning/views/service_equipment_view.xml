<odoo>
    <record id="view_service_equipment_form_planning" model="ir.ui.view">
        <field name="name">Service equipment</field>
        <field name="model">service.equipment</field>
        <field name="inherit_id" ref="deltatech_service_equipment_base.view_service_equipment_form"/>
        <field name="arch" type="xml">
            <field name="vendor_id" position="after">
                <field name="resource_id" force_save="1"/>
            </field>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object"
                        name="action_view_planning"
                        class="oe_stat_button" icon="fa-tasks"
                        string="Planning"
                        invisible="not resource_id"
                />
            </xpath>
            <xpath expr="//header" position="inside">
                    <button name="generate_resource_for_equipment" string="Generate Resource" type="object" class="btn-primary"
                        invisible="resource_id != False"/>

            </xpath>
        </field>
    </record>
</odoo>
